# Copy this file to .env and fill in your values before running the API locally.
# Never commit the actual .env file — it is listed in .gitignore.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# MongoDB connection string. Get one from https://cloud.mongodb.com (free tier).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── SendGrid ─────────────────────────────────────────────────────────────────
# Create a free SendGrid account at https://sendgrid.com and generate an API key.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email addresses ───────────────────────────────────────────────────────────
# The inbox that receives new contact-form submissions.
EMAIL_TO=your-business@example.com

# The verified sender address configured in your SendGrid account.
EMAIL_FROM=no-reply@yourdomain.com

# Display name shown in the "From" header of outbound emails.
EMAIL_FROM_NAME=Event Rules

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://21george.github.io,https://yourdomain.com
# Leave empty to allow all origins (not recommended for production).
CORS_ORIGIN=http://localhost:5173
